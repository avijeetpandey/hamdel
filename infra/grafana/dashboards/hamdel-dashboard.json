{
  "title": "Hamdel — Ingestion Pipeline",
  "uid": "hamdel-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ingestion RPS",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(hamdel_ingest_latency_seconds_count[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ingestion Avg Latency (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "(rate(hamdel_ingest_latency_seconds_sum[1m]) / rate(hamdel_ingest_latency_seconds_count[1m])) * 1000",
          "legendFormat": "Avg latency"
        },
        {
          "expr": "hamdel_ingest_latency_seconds_max * 1000",
          "legendFormat": "Max latency"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Kafka Consumption Rate (events/s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "rate(hamdel_kafka_consumed_total[1m])",
          "legendFormat": "consumed/s"
        },
        {
          "expr": "rate(hamdel_ingest_latency_seconds_count[1m])",
          "legendFormat": "ingested/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Circuit Breaker Open",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"kafkaProducer\",state=\"open\"}",
          "legendFormat": "CB Open"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "red",   "value": 1}
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Video Start Time (VST) avg ms",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [
        {"expr": "hamdel_kpi_vst_ms", "legendFormat": "VST avg"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Playback Failure Rate",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "targets": [
        {"expr": "hamdel_kpi_pfr", "legendFormat": "PFR"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rebuffering Ratio",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "targets": [
        {"expr": "hamdel_kpi_rebuf_ratio", "legendFormat": "Rebuf Ratio"}
      ]
    }
  ]
}
